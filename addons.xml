<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="repository.brendansbuild"
           name="BrendansBuild"
           version="1.0.3"
           provider-name="user805643">
        <extension point="xbmc.addon.repository" name="BrendansBuild">
            <dir minversion="21.0.0">
                <info compressed="false">https://raw.githubusercontent.com/user805643/BrendansBuild/main/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/user805643/BrendansBuild/main/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/user805643/BrendansBuild/main/zips/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">BrendansBuild Kodi repository</summary>
            <description lang="en_GB">Personal Kodi repository for Brendan build installs and updates.</description>
            <platform>all</platform>
        </extension>
    </addon>

<addon id="plugin.program.brendanswizard"
       name="[COLOR gold]Brendans[/COLOR] Wizard"
       version="1.0.4"
       provider-name="Brendan">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
        <import addon="script.module.requests" />
        <import addon="script.module.six" />
        <import addon="script.kodi.android.update" optional="true" version="1.1.7" />
        <import addon="script.speedtester" optional="true" version="1.1.2" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.service" library="startup.py" start="startup" />
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">[COLOR gold]Brendans Fully Loaded Bingie System[/COLOR]</summary>
        <description lang="en_GB">A fully loaded Kodi wizard for installing and maintaining Brendans Bingie setup.</description>
        <platform>all</platform>
        <news>1.0.4
 - Refreshed add-on metadata and branding
 - Updated gold title styling and artwork references
 - Improved repository listing compatibility for icon and fanart
</news>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.png</fanart>
        </assets>
    </extension>
</addon>